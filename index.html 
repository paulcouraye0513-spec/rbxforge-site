function savePortfolio(){
  const ct=document.querySelectorAll("#adm-plist > div").length;
  const projs=Array.from({length:ct},(_,i)=>({
    n:document.getElementById("pn"+i).value,
    d:document.getElementById("pd"+i).value,
    t:document.getElementById("pt"+i).value.split(",").map(x=>x.trim()).filter(Boolean)
  }));
  const d=sg("rbxf_site")||{}; d.projects=projs; ss("rbxf_site",d);
  projs.forEach((p,i)=>{
    const en=document.getElementById("p"+i+"n"), ed=document.getElementById("p"+i+"d"), et=document.getElementById("p"+i+"t");
    if(en) en.textContent=p.n; if(ed) ed.textContent=p.d;
    if(et) et.innerHTML=p.t.map(t=>`<span class="tag">${t}</span>`).join("");
  });
  showOk("ok-po");
}

function saveLink(){
  const l=document.getElementById("a-link").value.trim();
  if(!l.startsWith("http")){ alert("URL invalide !"); return; }
  const d=sg("rbxf_site")||{}; d.rLink=l; ss("rbxf_site",d);
  document.getElementById("rblx-btn").href=l;
  showOk("ok-li");
}

function savePw(){
  const p1=document.getElementById("a-p1").value;
  const p2=document.getElementById("a-p2").value;
  const c2=document.getElementById("a-p2c").value;
  if(!p1||p1.length<4){ alert("Mot de passe 1 trop court !"); return; }
  if(!p2||p2.length<4){ alert("Mot de passe 2 trop court !"); return; }
  if(p2!==c2){ alert("Confirmation incorrecte !"); return; }
  if(p1===p2){ alert("Les deux mots de passe doivent être différents !"); return; }
  ss("adm_p1",p1); ss("adm_p2",p2);
  ["a-p1","a-p2","a-p2c"].forEach(id=>document.getElementById(id).value="");
  showOk("ok-se");
}

function delRev(idx){
  if(!confirm("Supprimer cet avis ?")) return;
  const revs=sg("rbxf_revs")||[]; revs.splice(idx,1); ss("rbxf_revs",revs);
  renderRevs(); loadAdmPanel();
}

