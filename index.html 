];

function starsH(n){ return "<span style=\"color:var(--lime)\">"+"★".repeat(n)+"</span><span style=\"color:var(--border)\">"+"☆".repeat(5-n)+"</span>"; }

function renderRevs(){
  const user = sg("rbxf_revs")||[];
  const all = [...STARTER,...user];
  const avg = (all.reduce((s,r)=>s+r.stars,0)/all.length).toFixed(1);
  document.getElementById("avg-sc").textContent = avg;
  document.getElementById("avg-st").innerHTML = starsH(Math.round(parseFloat(avg)));
  document.getElementById("avg-cn").textContent = all.length+" avis";
  const grid = document.getElementById("rev-grid");
  grid.innerHTML = [...user].reverse().concat(STARTER).map(r=>`
    <div class="rcard">
      <div class="rstars">${starsH(r.stars)}</div>
      <div class="rtext">${r.text.replace(/</g,"&lt;")}</div>
      <div class="rauthor">@${r.name.replace(/</g,"&lt;")}</div>
      <div class="rdate">${r.date}</div>
    </div>`).join("");
}

let selStar = 0;
document.querySelectorAll(".sp").forEach(s=>{
  s.addEventListener("mouseover",()=>hStars(+s.dataset.v));
  s.addEventListener("mouseout",()=>hStars(selStar));
  s.addEventListener("click",()=>{ selStar=+s.dataset.v; hStars(selStar); });
});
function hStars(n){ document.querySelectorAll(".sp").forEach(s=>s.classList.toggle("on",+s.dataset.v<=n)); }

function postReview(){
  const name=document.getElementById("rname").value.trim();
  const text=document.getElementById("rtext").value.trim();
  if(!selStar){alert(lang==="fr"?"Choisis une note en étoiles !":"Choose a star rating!");return;}
  if(!name||name.length<3){alert(lang==="fr"?"Entre ton pseudo Roblox !":"Enter your Roblox username!");return;}
  if(!text||text.length<10){alert(lang==="fr"?"Écris un commentaire plus détaillé !":"Write a more detailed comment!");return;}
  const revs = sg("rbxf_revs")||[];
  revs.push({stars:selStar,name,text,date:new Date().toLocaleDateString("fr-FR",{day:"numeric",month:"long",year:"numeric"})});
  ss("rbxf_revs",revs);
  document.getElementById("rname").value="";
  document.getElementById("rtext").value="";
  selStar=0; hStars(0);
  const ok=document.getElementById("rev-ok");
  ok.style.display="block"; setTimeout(()=>ok.style.display="none",3000);
  renderRevs();
}

// ── FAQ
function tfaq(btn){
  const a=btn.nextElementSibling, open=a.classList.contains("open");
  document.querySelectorAll(".faq-a").forEach(x=>x.classList.remove("open"));
  document.querySelectorAll(".faq-q").forEach(x=>x.classList.remove("open"));
  if(!open){a.classList.add("open");btn.classList.add("open");}
}

// ── SITE DATA
function loadSiteData(){
  const d = sg("rbxf_site")||{};
  if(d.rLink) document.getElementById("rblx-btn").href = d.rLink;
  if(d.members) d.members.forEach((m,i)=>{
    const el_i=document.getElementById("m"+i+"i"), el_n=document.getElementById("m"+i+"n"), el_r=document.getElementById("m"+i+"r");
    if(el_i) el_i.textContent=m.i;
    if(el_n) el_n.textContent=m.n;
    if(el_r) el_r.textContent=m.r;
  });
  if(d.projects) d.projects.forEach((p,i)=>{
    const en=document.getElementById("p"+i+"n"), ed=document.getElementById("p"+i+"d"), et=document.getElementById("p"+i+"t");
    if(en) en.textContent=p.n;
    if(ed) ed.textContent=p.d;
    if(et) et.innerHTML=p.t.map(t=>`<span class="tag">${t}</span>`).join("");
  });
  if(d.avail) applyAvail(d.avail);
}

