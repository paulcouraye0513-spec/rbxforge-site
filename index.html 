  // ── NOM DE JEU
  if(svcs.includes("nomjeu")){
    q.push({id:"nj_style",l:"Quel style de nom tu veux ?",h:"Un seul choix",t:"single",o:[
      {id:"njs1",l:"Court & percutant",i:"⚡",d:"1-2 mots, facile à retenir"},
      {id:"njs2",l:"Descriptif",i:"📝",d:"Explique ce que le jeu fait"},
      {id:"njs3",l:"Mystérieux / épique",i:"🌑",d:"Crée une atmosphère"},
      {id:"njs4",l:"Fun / humoristique",i:"😂",d:"Léger, accrocheur, drôle"}
  ]});
    q.push({id:"nj_qty",l:"Combien de propositions tu veux ?",h:"Un seul choix",t:"single",o:[
      {id:"njq1",l:"3 propositions",i:"🎯",d:"Le minimum pour choisir"},
      {id:"njq2",l:"5 propositions",i:"🎯🎯",d:"Plus de choix"},
      {id:"njq3",l:"10 propositions",i:"🎯🎯🎯",d:"Large sélection"},
      {id:"njq4",l:"Pack complet (10 noms + slogans)",i:"💎",d:"Noms + accroches pour chaque"}
  ]});
  }

  // ── PUBLICITE
  if(svcs.includes("pub")){
    q.push({id:"pub_type",l:"Quel type de pub tu veux ?",h:"Plusieurs choix possibles",t:"multi",o:[
      {id:"pt1",l:"Stratégie TikTok / réseaux",i:"📱"},
      {id:"pt2",l:"Thumbnail clickbait optimisée",i:"🖼️"},
      {id:"pt3",l:"Description & tags SEO Roblox",i:"🔍"},
      {id:"pt4",l:"Plan de lancement complet",i:"🚀"},
      {id:"pt5",l:"Conseils sponsoring YouTubeurs",i:"🎥"},
      {id:"pt6",l:"Pub dans d'autres jeux Roblox",i:"🎮"}
  ]});
    q.push({id:"pub_budget",l:"Quelle envergure pour la pub ?",h:"Un seul choix",t:"single",o:[
      {id:"pb1",l:"Conseils seulement",i:"💡",d:"Stratégie que tu appliques toi-même"},
      {id:"pb2",l:"On gère pour toi",i:"📊",d:"On s'occupe de tout"},
      {id:"pb3",l:"Campagne complète",i:"🚀",d:"Multi-canaux, suivi inclus"}
  ]});
    q.push({id:"pub_cible",l:"Quelle audience tu cibles ?",h:"Un seul choix",t:"single",o:[
      {id:"pc1",l:"Grand public Roblox",i:"🌍",d:"Tous les profils"},
      {id:"pc2",l:"Fans d'un genre spécifique",i:"🎯",d:"Obby, RPG, tycoon…"},
      {id:"pc3",l:"Joueurs compétitifs",i:"🏆",d:"Fans de challenge"},
      {id:"pc4",l:"Enfants / familles",i:"👶",d:"Contenu accessible"}
  ]});
  }

  // Qualité et délai seulement pour les services créatifs (pas nomjeu/pub seuls)
  const needsQuality = svcs.some(s => !["nomjeu","pub"].includes(s));
  if(needsQuality){
    q.push({id:"quality",l:"Niveau de qualité visuelle ?",h:"Un seul choix",t:"single",o:[
      {id:"ql1",l:"Basique",i:"⚡",d:"Fonctionnel"},{id:"ql2",l:"Normal",i:"✅",d:"Propre et cohérent"},
      {id:"ql3",l:"Soigné",i:"✨",d:"Joli, agréable"},{id:"ql4",l:"Premium",i:"💎",d:"Niveau pro"}]});
  }
  q.push({id:"deadline",l:"Délai souhaité ?",h:"Un seul choix",t:"single",o:[
    {id:"dl1",l:"Flexible",i:"🐢",d:"Pas pressé"},{id:"dl2",l:"Normal (1-2 semaines)",i:"📅",d:"Standard"},
    {id:"dl3",l:"Rapide (sous 1 semaine)",i:"⚡",d:"+25%"},{id:"dl4",l:"ASAP (2-3 jours)",i:"🔥",d:"+60%"}]});
  return q;
}

let W = {phase:"svc",svcs:[],qs:[],qi:0,ans:{}};
const ALL_SECS = ["how-sec","team-sec","pay-sec","contact-sec","port-sec","faq-sec","rev-sec"];

function startWizard(){
  document.getElementById("hero").style.display="none";
  ALL_SECS.forEach(id=>{ const el=document.getElementById(id); if(el) el.style.display="none"; });
  // hide delay section (no id, find it)
  document.querySelectorAll(".section.wrap-sm").forEach(el=>el.style.display="none");
  document.getElementById("wizard").style.display="block";
  renderSvcStep();
  window.scrollTo({top:0,behavior:"smooth"});
}

function restartWizard(){
  W={phase:"svc",svcs:[],qs:[],qi:0,ans:{}};
  document.getElementById("result").style.display="none";
  document.getElementById("wizard").style.display="none";
  document.getElementById("hero").style.display="flex";
  ALL_SECS.forEach(id=>{ const el=document.getElementById(id); if(el) el.style.display=""; });
  document.querySelectorAll(".section.wrap-sm").forEach(el=>el.style.display="");
  window.scrollTo({top:0,behavior:"smooth"});
}

function renderSvcStep(){
  W.phase="svc";
  let html=`<div class="step active"><p class="sl">Étape 1 — Services</p>
    <h2 class="st">Tu as besoin de quoi ?</h2>
    <p class="sh">Plusieurs choix possibles</p><div class="cgrid">`;
  SVCS.forEach(s=>{
    const sel=W.svcs.includes(s.id)?"sel":"";
    html+=`<div class="crd ${sel}" id="sv-${s.id}" onclick="togSvc('${s.id}')">
      <div class="cck"><i class="fas fa-check"></i></div>
      <div class="cico">${s.icon}</div><div class="cnm">${s.label}</div><div class="cds">${s.desc}</div></div>`;
  });
  html+=`</div></div>`;
  document.getElementById("steps").innerHTML=html;
  setProgress(1,null);
  document.getElementById("btn-prev").style.display="none";
  document.getElementById("btn-next").querySelector("#next-lbl").textContent=tx("nxt");
}

function togSvc(id){
  if(W.svcs.includes(id)){ W.svcs=W.svcs.filter(x=>x!==id); document.getElementById("sv-"+id).classList.remove("sel"); }
  else{ W.svcs.push(id); document.getElementById("sv-"+id).classList.add("sel"); }
}

function renderQ(idx){
  const q=W.qs[idx], tot=W.qs.length+1, cur=idx+2;
  let html=`<div class="step active"><p class="sl">Étape ${cur}</p>
    <h2 class="st">${q.l}</h2><p class="sh">${q.h}</p>
    <div class="cgrid${q.t==="single"?" two":""}">`;
  q.o.forEach(opt=>{
    const sel=q.t==="multi"?(W.ans[q.id]||[]).includes(opt.id):W.ans[q.id]===opt.id;
    html+=`<div class="crd${sel?" sel":""}" id="op-${q.id}-${opt.id}" onclick="selAns('${q.id}','${opt.id}','${q.t}')">
      ${q.t==="multi"?'<div class="cck"><i class="fas fa-check"></i></div>':""}
      <div class="cico">${opt.i}</div><div class="cnm">${opt.l}</div>${opt.d?`<div class="cds">${opt.d}</div>`:""}</div>`;
  });
  html+=`</div></div>`;
  document.getElementById("steps").innerHTML=html;
  setProgress(cur,tot+1);
  document.getElementById("btn-prev").style.display="inline-block";
  const isLast=idx===W.qs.length-1;
  document.getElementById("btn-next").innerHTML=isLast
    ?`${lang==="fr"?"Voir l'estimation":"See estimate"} →`
    :`<span id="next-lbl">${tx("nxt")}</span> →`;
}

function selAns(qId,optId,type){
  if(type==="multi"){
    if(!W.ans[qId]) W.ans[qId]=[];
    const arr=W.ans[qId], el=document.getElementById(`op-${qId}-${optId}`);
    if(arr.includes(optId)){ W.ans[qId]=arr.filter(x=>x!==optId); el.classList.remove("sel"); }
    else{ arr.push(optId); el.classList.add("sel"); }
  } else {
    W.qs[W.qi].o.forEach(opt=>document.getElementById(`op-${qId}-${opt.id}`)?.classList.remove("sel"));
    W.ans[qId]=optId;
    document.getElementById(`op-${qId}-${optId}`).classList.add("sel");
  }
}

function nextStep(){
  if(W.phase==="svc"){
    if(!W.svcs.length){ shakeBtn(); return; }
    W.qs=buildQs(W.svcs); W.qi=0; W.phase="qs"; renderQ(0); return;
  }
  if(W.phase!=="qs") return;
  const q=W.qs[W.qi];
  if(!q) return;
  const ans=W.ans[q.id];
  const has=q.t==="multi"?(ans&&ans.length>0):!!ans;
  if(!has){ shakeBtn(); return; }
  if(W.qi<W.qs.length-1){ W.qi++; renderQ(W.qi); }
  else{ W.phase="done"; genResult(); }
}

function prevStep(){
  if(W.phase==="qs"&&W.qi===0){ W.phase="svc"; W.svcs=[]; W.ans={}; renderSvcStep(); return; }
  if(W.phase==="qs"&&W.qi>0){ W.qi--; renderQ(W.qi); }
}

function shakeBtn(){
  const b=document.getElementById("btn-next");
  b.style.transform="translateX(-8px)";
  setTimeout(()=>b.style.transform="translateX(8px)",100);
  setTimeout(()=>b.style.transform="translateX(-4px)",200);
  setTimeout(()=>b.style.transform="",300);
}

function setProgress(cur,tot){
  const pct=tot?Math.round(cur/tot*100):10;
  document.getElementById("prog-f").style.width=pct+"%";
  document.getElementById("prog-txt").textContent=`Étape ${cur}${tot?" sur "+tot:""}`;
  document.getElementById("prog-fr").textContent=tot?`${cur}/${tot}`:"…";
}

function calcPrice(){
  const a=W.ans, s=W.svcs; let b=0;
  const bm={map:700,script:400,ui:350,gameplay:900,image:200,imagejeu:250,monetize:600,dialogues:450,complet:4000,nomjeu:80,pub:350};
  s.forEach(x=>b+=bm[x]||0);
  if(s.includes("map")){ b+=({xs:0,sm:300,md:800,lg:1800}[a.map_size]||0)+(a.map_type||[]).length*150; }
  if(s.includes("script")){ b+=({s1:0,s2:300,s3:700,s4:1400}[a.sc_lvl]||0)+(a.sc_type||[]).length*80; }
  if(s.includes("ui")){ b+=({u1:0,u2:200,u3:300,u4:400}[a.ui_style]||0)+(a.ui_screens||[]).length*100; }
  if(s.includes("gameplay")){ b+=({gd1:0,gd2:400,gd3:900,gd4:1600}[a.gp_depth]||0)+(a.gp_type||[]).length*120; }
  if(s.includes("image")){ b+=({q1:0,q2:200,q3:600,q4:1200}[a.as_qty]||0); }
  if(s.includes("monetize")){ b+=(a.mo_type||[]).length*150; }
  if(s.includes("dialogues")){ b+=({dq1:0,dq2:200,dq3:500,dq4:1000}[a.di_qty]||0); }
  if(s.includes("complet")){ b+=({cs1:0,cs2:1000,cs3:2500,cs4:5000}[a.cp_scope]||0); }
  const dm={ql1:.75,ql2:1,ql3:1.5,ql4:2.2}[a.quality]||1.0;
  const dd={dl1:.9,dl2:1,dl3:1.25,dl4:1.6}[a.deadline]||1.0;
  const tot=Math.round(b*dm*dd);
  return {min:Math.max(200,Math.round(tot*.85)),max:Math.round(tot*1.15),base:Math.round(b)};
}

function genResult(){
  document.getElementById("wizard").style.display="none";
  document.getElementById("result").style.display="block";
  const p=calcPrice(), a=W.ans;
  const svcL=W.svcs.map(id=>SVCS.find(s=>s.id===id)?.label).join(", ");
  const qL={ql1:"Basique",ql2:"Normal",ql3:"Soigné",ql4:"Premium"}[a.quality]||"—";
  const dL={dl1:"Flexible",dl2:"Normal (1-2 semaines)",dl3:"Rapide (+25%)",dl4:"ASAP (+60%)"}[a.deadline]||"—";
