  const projs=d.projects||[{n:"Obby / Parkour",d:"Jeu de plateforme coloré.",t:["Map","Scripts","UI"]},{n:"Ville RP",d:"Ville complète.",t:["Map","Social RP"]},{n:"Île — Dernier Signal",d:"Île survie.",t:["IA","Gameplay"]}];
  document.getElementById("adm-plist").innerHTML=projs.map((p,i)=>`
    <div style="background:var(--card);border:1px solid var(--border);border-radius:8px;padding:10px;margin-bottom:8px">
      <div class="adm-f"><label class="adm-lb">Nom</label><input class="adm-in" id="pn${i}" value="${p.n}"></div>
      <div class="adm-f"><label class="adm-lb">Description</label><textarea class="adm-ta" id="pd${i}" rows="2">${p.d}</textarea></div>
      <div class="adm-f"><label class="adm-lb">Tags (virgules)</label><input class="adm-in" id="pt${i}" value="${p.t.join(", ")}"></div>
    </div>`).join("");
  // Reviews
  const revs=sg("rbxf_revs")||[];
  const rl=document.getElementById("adm-rlist"), rn=document.getElementById("adm-rnone");
  if(!revs.length){ rl.innerHTML=""; rn.style.display="block"; }
  else{
    rn.style.display="none";
    rl.innerHTML=revs.map((r,i)=>`
      <div class="rev-row">
        <div><div style="color:var(--lime);font-weight:700;font-size:.72rem">@${r.name} ${"★".repeat(r.stars)}</div>
        <div style="color:var(--muted);font-size:.72rem">${r.text}</div></div>
