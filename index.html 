<!DOCTYPE html>
<html lang="fr" id="html-root">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>RbxForge — Création de jeux Roblox sur mesure</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
<style>
:root{--lime:#b8f727;--bg:#080c08;--surface:#0f1a0f;--card:#131f13;--card2:#1a2e1a;--border:#1e321e;--text:#e8f5e8;--muted:#5a7a5a;--white:#fff;--orange:#ff6b35;--os:#ff9966;}
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
body{font-family:'Syne',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(184,247,39,.04) 1px,transparent 1px),linear-gradient(90deg,rgba(184,247,39,.04) 1px,transparent 1px);background-size:60px 60px;pointer-events:none;z-index:0;}
@keyframes fadeUp{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:none}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* NAV */
nav{position:sticky;top:0;z-index:100;background:rgba(8,12,8,.93);backdrop-filter:blur(14px);border-bottom:1px solid var(--border);padding:14px 28px;display:flex;align-items:center;justify-content:space-between;gap:10px;flex-wrap:wrap;}
.nav-logo{font-size:1.4rem;font-weight:800;color:var(--lime);display:flex;align-items:center;gap:8px;}
.nav-right{display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
.visitor-counter{font-family:'Space Mono',monospace;font-size:.68rem;color:var(--muted);letter-spacing:.08em;display:flex;align-items:center;gap:5px;}
.vdot{width:7px;height:7px;border-radius:50%;background:var(--lime);box-shadow:0 0 6px var(--lime);animation:pulse 2s infinite;}
.lang-btn{font-family:'Space Mono',monospace;font-size:.66rem;letter-spacing:.1em;text-transform:uppercase;background:none;border:1.5px solid var(--border);color:var(--muted);padding:5px 11px;border-radius:99px;cursor:pointer;transition:all .2s;}
.lang-btn:hover{border-color:var(--lime);color:var(--lime);}
.avail{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;display:flex;align-items:center;gap:5px;padding:5px 11px;border-radius:99px;border:1.5px solid;}
.avail.open{color:#4ade80;border-color:#4ade80;background:rgba(74,222,128,.08);}
.avail.full{color:var(--os);border-color:var(--orange);background:rgba(255,107,53,.08);}
.avdot{width:6px;height:6px;border-radius:50%;background:currentColor;animation:pulse 2s infinite;}

/* HERO */
#hero{position:relative;z-index:1;min-height:calc(100vh - 56px);display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;padding:60px 20px;}
.hero-ey{font-family:'Space Mono',monospace;font-size:.7rem;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);margin-bottom:24px;opacity:0;animation:fadeUp .6s .1s forwards;}
.hero-t{font-size:clamp(2.6rem,8vw,5.8rem);font-weight:800;line-height:1;letter-spacing:-.03em;color:var(--white);margin-bottom:14px;opacity:0;animation:fadeUp .6s .2s forwards;}
.hero-t span{color:var(--lime);}
.hero-s{font-size:clamp(.9rem,2vw,1.05rem);color:var(--muted);max-width:520px;line-height:1.7;margin-bottom:44px;opacity:0;animation:fadeUp .6s .35s forwards;}
.btn-start{font-family:'Space Mono',monospace;font-size:.9rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;background:var(--lime);color:#080c08;border:none;cursor:pointer;padding:17px 44px;border-radius:100px;transition:transform .2s,box-shadow .2s;opacity:0;animation:fadeUp .6s .5s forwards;}
.btn-start:hover{transform:translateY(-3px);box-shadow:0 20px 60px rgba(184,247,39,.35);}
.hero-stats{margin-top:64px;display:flex;gap:36px;flex-wrap:wrap;justify-content:center;opacity:0;animation:fadeUp .6s .65s forwards;}
.stat-n{font-size:1.6rem;font-weight:800;color:var(--lime);}
.stat-l{font-size:.72rem;color:var(--muted);margin-top:2px;}

/* SECTIONS */
.section{position:relative;z-index:1;}
.sec-ey{font-family:'Space Mono',monospace;font-size:.66rem;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);margin-bottom:10px;text-align:center;}
.sec-t{font-size:clamp(1.25rem,3vw,1.85rem);font-weight:800;color:var(--white);text-align:center;margin-bottom:8px;}
.sec-s{font-size:.85rem;color:var(--muted);text-align:center;line-height:1.6;margin-bottom:32px;}
.wrap{max-width:880px;margin:0 auto;padding:64px 20px;}
.wrap-sm{max-width:700px;margin:0 auto;padding:64px 20px;}

/* HOW */
.how-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;}
@media(max-width:600px){.how-grid{grid-template-columns:1fr;}}
.how-card{background:var(--card);border:1.5px solid var(--border);border-radius:16px;padding:26px 20px;transition:border-color .2s,transform .2s;position:relative;}
.how-card:hover{border-color:var(--lime);transform:translateY(-3px);}
.how-num{font-family:'Space Mono',monospace;font-size:2.2rem;font-weight:700;color:var(--border);line-height:1;margin-bottom:12px;}
.how-ico{font-size:1.6rem;margin-bottom:9px;}
.how-ti{font-size:.95rem;font-weight:700;color:var(--white);margin-bottom:5px;}
.how-de{font-size:.78rem;color:var(--muted);line-height:1.6;}
@media(min-width:601px){.how-card::after{content:'→';position:absolute;right:-18px;top:50%;transform:translateY(-50%);color:var(--lime);font-size:1.1rem;z-index:2;}.how-card:last-child::after{display:none;}}

/* DELAYS */
.delays-t{width:100%;border-collapse:separate;border-spacing:0 7px;}
.delays-t th{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);padding:0 14px 6px;text-align:left;}
.delays-t td{background:var(--card);padding:13px 14px;font-size:.83rem;border-top:1.5px solid var(--border);border-bottom:1.5px solid var(--border);}
.delays-t td:first-child{border-left:1.5px solid var(--border);border-radius:9px 0 0 9px;}
.delays-t td:last-child{border-right:1.5px solid var(--border);border-radius:0 9px 9px 0;color:var(--lime);font-family:'Space Mono',monospace;font-size:.75rem;}
.delays-t tr:hover td{border-color:var(--lime);}

/* TEAM */
.team-bg{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);}
.team-members{display:flex;justify-content:center;gap:14px;flex-wrap:wrap;margin-top:6px;}
.mc{background:var(--card);border:1.5px solid var(--border);border-radius:14px;padding:20px 18px;min-width:150px;text-align:center;transition:border-color .2s,transform .2s;}
.mc:hover{border-color:var(--lime);transform:translateY(-3px);}
.mc-av{font-size:1.8rem;margin-bottom:9px;}
.mc-n{font-size:.9rem;font-weight:700;color:var(--white);margin-bottom:4px;}
.mc-r{font-size:.7rem;color:var(--muted);line-height:1.5;}
.boss-box{background:rgba(184,247,39,.07);border:1.5px solid rgba(184,247,39,.25);border-radius:12px;padding:14px 18px;text-align:center;margin-bottom:22px;max-width:560px;margin-left:auto;margin-right:auto;}

/* PAYMENT */
.pay-grid{display:grid;grid-template-columns:1fr 1fr;gap:13px;}
@media(max-width:540px){.pay-grid{grid-template-columns:1fr;}}
.pc{background:var(--card);border:1.5px solid var(--border);border-radius:16px;padding:22px 18px;}
.pc.hi{border-color:var(--lime);}
.pc-ico{font-size:1.7rem;margin-bottom:9px;}
.pc-t{font-size:.9rem;font-weight:700;color:var(--white);margin-bottom:6px;}
.pc-d{font-size:.78rem;color:var(--muted);line-height:1.6;}
.ptag{display:inline-block;margin-top:9px;font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.1em;text-transform:uppercase;background:rgba(184,247,39,.12);color:var(--lime);border-radius:99px;padding:2px 9px;}

/* CONTACT */
.contact-wrap{max-width:560px;margin:0 auto;padding:50px 20px 0;}
.contact-box{background:var(--card);border:2px solid var(--lime);border-radius:20px;padding:36px 28px;text-align:center;}
.ct{font-size:1.25rem;font-weight:800;color:var(--white);margin-bottom:12px;}
.csteps{text-align:left;display:inline-block;font-size:.81rem;line-height:2.1;margin-bottom:18px;}
.cbtn{display:inline-flex;align-items:center;gap:9px;background:var(--lime);color:#080c08;font-family:'Space Mono',monospace;font-weight:700;font-size:.82rem;letter-spacing:.06em;text-transform:uppercase;padding:13px 28px;border-radius:100px;text-decoration:none;border:none;cursor:pointer;transition:all .2s;margin-bottom:14px;}
.cbtn:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(184,247,39,.3);}
.mail-box{background:rgba(184,247,39,.06);border:1px solid rgba(184,247,39,.2);border-radius:10px;padding:12px 14px;font-size:.8rem;line-height:1.8;margin-top:4px;}

/* PORTFOLIO */
.pg{display:grid;grid-template-columns:repeat(3,1fr);gap:13px;}
@media(max-width:680px){.pg{grid-template-columns:1fr 1fr;}}
@media(max-width:400px){.pg{grid-template-columns:1fr;}}
.pcard{background:var(--card);border:1.5px solid var(--border);border-radius:14px;overflow:hidden;transition:border-color .2s,transform .2s;}
.pcard:hover{border-color:var(--lime);transform:translateY(-3px);}
.pimg{width:100%;aspect-ratio:16/9;position:relative;overflow:hidden;}
.pimg img{width:100%;height:100%;object-fit:cover;display:block;}
.wip{position:absolute;top:7px;right:7px;font-family:'Space Mono',monospace;font-size:.56rem;letter-spacing:.1em;text-transform:uppercase;background:rgba(255,180,0,.15);color:#ffb400;border-radius:99px;padding:2px 8px;border:1px solid rgba(255,180,0,.3);}
.pinfo{padding:12px 13px;}
.pn{font-size:.86rem;font-weight:700;color:var(--white);margin-bottom:3px;}
.pd{font-size:.72rem;color:var(--muted);line-height:1.4;}
.ptags{display:flex;gap:5px;flex-wrap:wrap;margin-top:8px;}
.tag{font-family:'Space Mono',monospace;font-size:.56rem;background:rgba(184,247,39,.1);color:var(--lime);border-radius:99px;padding:2px 7px;}

/* FAQ */
.faq-item{border:1.5px solid var(--border);border-radius:12px;margin-bottom:8px;overflow:hidden;transition:border-color .2s;}
.faq-item:hover{border-color:var(--lime);}
.faq-q{width:100%;background:var(--card);border:none;padding:15px 17px;color:var(--white);font-family:'Syne',sans-serif;font-size:.9rem;font-weight:700;text-align:left;cursor:pointer;display:flex;justify-content:space-between;align-items:center;gap:10px;}
.faq-q i{color:var(--lime);transition:transform .2s;flex-shrink:0;}
.faq-q.open i{transform:rotate(45deg);}
.faq-a{display:none;padding:0 17px 15px;background:var(--card);font-size:.8rem;color:var(--muted);line-height:1.7;}
.faq-a.open{display:block;}

/* REVIEWS */
.rev-avg{display:flex;align-items:center;justify-content:center;gap:11px;margin-top:10px;}
.avg-sc{font-size:2.1rem;font-weight:800;color:var(--lime);line-height:1;}
.rev-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin:24px 0;}
@media(max-width:520px){.rev-grid{grid-template-columns:1fr;}}
.rcard{background:var(--card);border:1.5px solid var(--border);border-radius:14px;padding:18px;}
.rstars{font-size:.9rem;margin-bottom:7px;letter-spacing:2px;}
.rtext{font-size:.8rem;color:var(--muted);line-height:1.6;margin-bottom:9px;}
.rauthor{font-size:.7rem;color:var(--lime);font-weight:700;}
.rdate{font-size:.65rem;color:var(--muted);margin-top:2px;font-family:'Space Mono',monospace;}
.add-rev{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:26px 22px;}
.add-rev-t{font-size:.9rem;font-weight:700;color:var(--white);margin-bottom:16px;}
.spick{display:flex;gap:5px;margin-bottom:13px;font-size:1.6rem;cursor:pointer;}
.sp{transition:transform .15s;color:var(--border);}
.sp.on,.sp:hover{color:var(--lime);}
.sp:hover{transform:scale(1.2);}
.rinput{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:10px;padding:11px 13px;color:var(--text);font-family:'Syne',sans-serif;font-size:.85rem;resize:vertical;min-height:78px;margin-bottom:9px;outline:none;transition:border-color .2s;}
.rinput:focus{border-color:var(--lime);}
.rinput::placeholder{color:var(--muted);}
.rname{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:10px;padding:10px 13px;color:var(--text);font-family:'Syne',sans-serif;font-size:.85rem;margin-bottom:9px;outline:none;transition:border-color .2s;}
.rname:focus{border-color:var(--lime);}
.rname::placeholder{color:var(--muted);}
.btn-sub{font-family:'Space Mono',monospace;font-size:.76rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:var(--lime);color:#080c08;border:none;padding:11px 26px;border-radius:100px;cursor:pointer;transition:all .2s;}
.btn-sub:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(184,247,39,.3);}
.rev-ok{display:none;color:var(--lime);font-size:.76rem;margin-top:9px;font-family:'Space Mono',monospace;}

/* WIZARD */
#wizard{display:none;position:relative;z-index:1;min-height:100vh;padding:34px 18px 80px;}
.wiz-in{max-width:720px;margin:0 auto;}
.prog-h{display:flex;justify-content:space-between;align-items:center;margin-bottom:9px;}
.prog-l{font-family:'Space Mono',monospace;font-size:.7rem;color:var(--muted);letter-spacing:.1em;}
.prog-tr{height:4px;background:var(--border);border-radius:99px;margin-bottom:46px;overflow:hidden;}
.prog-f{height:100%;background:var(--lime);border-radius:99px;transition:width .5s cubic-bezier(.4,0,.2,1);}
.step{display:none;animation:fadeUp .4s forwards;}
.step.active{display:block;}
.sl{font-family:'Space Mono',monospace;font-size:.65rem;color:var(--lime);letter-spacing:.2em;text-transform:uppercase;margin-bottom:11px;}
.st{font-size:clamp(1.4rem,4vw,2.1rem);font-weight:800;line-height:1.15;color:var(--white);margin-bottom:6px;}
.sh{font-size:.83rem;color:var(--muted);margin-bottom:28px;}
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:9px;}
.cgrid.two{grid-template-columns:1fr 1fr;}
@media(max-width:400px){.cgrid,.cgrid.two{grid-template-columns:1fr 1fr;}}
.crd{background:var(--card);border:1.5px solid var(--border);border-radius:13px;padding:16px 14px;cursor:pointer;text-align:left;transition:all .2s;position:relative;overflow:hidden;}
.crd:hover{border-color:var(--lime);background:var(--card2);transform:translateY(-2px);}
.crd.sel{border-color:var(--lime);background:var(--card2);}
.crd.sel .cck{opacity:1;}
.cico{font-size:1.5rem;margin-bottom:9px;}
.cnm{font-size:.88rem;font-weight:700;color:var(--white);line-height:1.2;}
.cds{font-size:.71rem;color:var(--muted);margin-top:3px;line-height:1.4;}
.cck{position:absolute;top:10px;right:10px;width:19px;height:19px;background:var(--lime);border-radius:50%;display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity .2s;}
.cck i{font-size:.55rem;color:#080c08;font-weight:900;}
.wiz-nav{display:flex;justify-content:space-between;align-items:center;margin-top:36px;}
.btn-prev{font-family:'Space Mono',monospace;font-size:.8rem;background:none;border:1.5px solid var(--border);color:var(--muted);padding:12px 22px;border-radius:100px;cursor:pointer;transition:all .2s;}
.btn-prev:hover{border-color:var(--text);color:var(--text);}
.btn-next{font-family:'Space Mono',monospace;font-size:.84rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:var(--lime);color:#080c08;border:none;padding:13px 32px;border-radius:100px;cursor:pointer;transition:all .2s;margin-left:auto;}
.btn-next:hover{transform:translateY(-2px);box-shadow:0 12px 40px rgba(184,247,39,.3);}

/* RESULT */
#result{display:none;position:relative;z-index:1;padding:56px 18px 90px;}
.res-in{max-width:640px;margin:0 auto;}
.rbadge{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--lime);margin-bottom:13px;}
.rtitle{font-size:clamp(1.7rem,5vw,2.8rem);font-weight:800;color:var(--white);line-height:1.05;margin-bottom:32px;}
.pbox{background:var(--card);border:1.5px solid var(--lime);border-radius:20px;padding:36px 28px;text-align:center;margin-bottom:20px;position:relative;overflow:hidden;}
.pbox::before{content:'';position:absolute;top:-60px;left:50%;transform:translateX(-50%);width:260px;height:260px;background:radial-gradient(circle,rgba(184,247,39,.08) 0%,transparent 70%);}
.plabel{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.2em;text-transform:uppercase;color:var(--muted);margin-bottom:9px;}
.pamount{font-size:clamp(2rem,7vw,3.6rem);font-weight:800;color:var(--lime);line-height:1;position:relative;}
.punit{font-size:1rem;color:var(--muted);margin-top:4px;}
.pnote{font-size:.75rem;color:var(--muted);margin-top:12px;line-height:1.5;}
.sumbox{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:22px 26px;margin-bottom:18px;}
.sumi-t{font-family:'Space Mono',monospace;font-size:.63rem;letter-spacing:.15em;text-transform:uppercase;color:var(--muted);margin-bottom:12px;}
.sumi{display:flex;justify-content:space-between;align-items:flex-start;padding:8px 0;border-bottom:1px solid var(--border);font-size:.84rem;}
.sumi:last-child{border-bottom:none;}
.sk{color:var(--muted);}
.sv{color:var(--white);font-weight:600;text-align:right;max-width:60%;}
.payopts{background:var(--surface);border:1.5px solid var(--border);border-radius:16px;padding:18px 22px;margin-bottom:14px;}
.payopts h4{font-size:.8rem;font-weight:700;color:var(--white);margin-bottom:11px;}
.popt{display:flex;align-items:flex-start;gap:9px;padding:8px 0;border-bottom:1px solid var(--border);font-size:.78rem;}
.popt:last-child{border-bottom:none;}
.poi{font-size:.95rem;flex-shrink:0;margin-top:1px;}
.pot{color:var(--muted);line-height:1.5;}
.pot strong{color:var(--text);}
.btn-cta{display:flex;align-items:center;justify-content:center;gap:10px;width:100%;padding:18px 26px;background:var(--lime);color:#080c08;font-family:'Space Mono',monospace;font-weight:700;font-size:.9rem;letter-spacing:.06em;text-transform:uppercase;border:none;border-radius:13px;cursor:pointer;text-decoration:none;transition:all .2s;margin-bottom:12px;}
.btn-cta:hover{transform:translateY(-3px);box-shadow:0 20px 60px rgba(184,247,39,.35);}
.btn-rst{display:flex;align-items:center;justify-content:center;gap:7px;width:100%;padding:13px;background:none;border:1.5px solid var(--border);color:var(--muted);border-radius:13px;cursor:pointer;font-size:.84rem;transition:all .2s;}
.btn-rst:hover{border-color:var(--muted);color:var(--text);}

/* ADMIN */
#adm-ov{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,.88);backdrop-filter:blur(10px);align-items:center;justify-content:center;padding:18px;}
#adm-ov.show{display:flex;}
.adm-box{background:#0f1a0f;border:2px solid var(--lime);border-radius:18px;padding:30px 26px;width:100%;max-width:480px;max-height:92vh;overflow-y:auto;position:relative;}
.adm-ti{font-size:1.1rem;font-weight:800;color:var(--white);margin-bottom:3px;display:flex;align-items:center;gap:8px;}
.adm-su{font-size:.72rem;color:var(--muted);margin-bottom:20px;font-family:'Space Mono',monospace;}
.adm-x{position:absolute;top:13px;right:13px;background:none;border:none;color:var(--muted);font-size:1rem;cursor:pointer;transition:color .2s;}
.adm-x:hover{color:var(--white);}
.adm-f{margin-bottom:10px;}
.adm-lb{font-size:.71rem;color:var(--muted);margin-bottom:3px;display:block;}
.adm-in{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:8px;padding:8px 11px;color:var(--text);font-family:'Syne',sans-serif;font-size:.82rem;outline:none;transition:border-color .2s;}
.adm-in:focus{border-color:var(--lime);}
.adm-ta{width:100%;background:var(--card);border:1.5px solid var(--border);border-radius:8px;padding:8px 11px;color:var(--text);font-family:'Syne',sans-serif;font-size:.82rem;outline:none;resize:vertical;min-height:60px;transition:border-color .2s;}
.adm-ta:focus{border-color:var(--lime);}
.adm-btn{font-family:'Space Mono',monospace;font-size:.7rem;font-weight:700;letter-spacing:.06em;text-transform:uppercase;background:var(--lime);color:#080c08;border:none;padding:8px 18px;border-radius:99px;cursor:pointer;transition:all .2s;margin-top:2px;}
.adm-btn:hover{transform:translateY(-2px);}
.adm-btn.d{background:none;border:1.5px solid var(--orange);color:var(--os);}
.adm-ok{font-size:.7rem;color:var(--lime);margin-top:6px;font-family:'Space Mono',monospace;display:none;}
