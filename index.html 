function saveEquipe(){
  const mems=[0,1,2].map(i=>({i:document.getElementById("mi"+i).value,n:document.getElementById("mn"+i).value,r:document.getElementById("mr"+i).value}));
  const d=sg("rbxf_site")||{}; d.members=mems; ss("rbxf_site",d);
  mems.forEach((m,i)=>{
    const ei=document.getElementById("m"+i+"i"), en=document.getElementById("m"+i+"n"), er=document.getElementById("m"+i+"r");
    if(ei) ei.textContent=m.i; if(en) en.textContent=m.n; if(er) er.textContent=m.r;
  });
  showOk("ok-eq");
