// ── ADMIN
function getPws(){ return {p1:sg("adm_p1")||DEF_P1, p2:sg("adm_p2")||DEF_P2}; }
let admStep=1, keyQ=[];
document.addEventListener("keydown",e=>{
  keyQ.push(e.key==="A"?"a":e.key);
  if(keyQ.length>3) keyQ.shift();
  if(keyQ[0]==="Control"&&keyQ[1]==="Shift"&&keyQ[2]==="a"){ keyQ=[]; openAdm(); }
});
function openAdm(){
  admStep=1;
  document.getElementById("adm-lbl").textContent="Mot de passe 1";
  document.getElementById("adm-pw").value="";
  document.getElementById("adm-hint").style.display="none";
  document.getElementById("adm-login").style.display="block";
  document.getElementById("adm-panel").style.display="none";
  document.getElementById("adm-ov").classList.add("show");
}
function closeAdm(){ document.getElementById("adm-ov").classList.remove("show"); admStep=1; }
document.getElementById("adm-ov").addEventListener("click",e=>{ if(e.target.id==="adm-ov") closeAdm(); });
document.getElementById("adm-pw").addEventListener("keydown",e=>{ if(e.key==="Enter") checkPw(); });
function checkPw(){
  const pw=getPws(), val=document.getElementById("adm-pw").value, hint=document.getElementById("adm-hint");
  if(admStep===1){
    if(val===pw.p1){ admStep=2; document.getElementById("adm-lbl").textContent="Mot de passe 2"; document.getElementById("adm-pw").value=""; hint.style.display="none"; }
    else{ hint.style.display="block"; document.getElementById("adm-pw").value=""; }
  } else {
    if(val===pw.p2){ document.getElementById("adm-login").style.display="none"; document.getElementById("adm-panel").style.display="block"; loadAdmPanel(); }
    else{ hint.style.display="block"; document.getElementById("adm-pw").value=""; }
  }
}
function stab(name,btn){
  document.querySelectorAll(".tab").forEach(t=>t.classList.remove("on"));
  document.querySelectorAll(".apanel").forEach(p=>p.classList.remove("on"));
  document.getElementById("ap-"+name).classList.add("on");
  if(btn) btn.classList.add("on");
}
function showOk(id){ const el=document.getElementById(id); el.style.display="block"; setTimeout(()=>el.style.display="none",2500); }

function loadAdmPanel(){
  const d=sg("rbxf_site")||{};
  document.getElementById("a-htit").value=document.querySelector(".hero-t")?.innerText||"";
