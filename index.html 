    <div style="animation:fadeUp .5s forwards">
      <p class="rbadge">✦ Estimation générée</p>
      <h2 class="rtitle">Voilà ton<br><span style="color:var(--lime)">estimation</span></h2>
      <div class="pbox">
        <p class="plabel">PRIX ESTIMÉ EN ROBUX</p>
        <p class="pamount">${p.min.toLocaleString("fr-FR")} — ${p.max.toLocaleString("fr-FR")}</p>
